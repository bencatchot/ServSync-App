{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "demo:seed": "node scripts/demo/seed-demo-scenario.mjs seed water_heater_core_loop",
    "demo:reset": "node scripts/demo/seed-demo-scenario.mjs reset water_heater_core_loop",
    "demo:verify": "node scripts/demo/seed-demo-scenario.mjs verify water_heater_core_loop",
    "demo:checkpoints": "node scripts/demo/seed-demo-scenario.mjs checkpoints",
    "qa": "npm run typecheck && npm run build",
    "qa:e2e": "npm run typecheck && npm run build && npm run test:e2e",
    "qa:e2e:geocoding": "playwright test tests/e2e/discover-geocoding-radius.spec.ts",
    "qa:e2e:mobile": "playwright test tests/e2e/mobile-smoke.spec.ts",
    "qa:e2e:mutating": "playwright test tests/e2e/contractor-create-customer.spec.ts tests/e2e/contractor-create-job.spec.ts tests/e2e/contractor-create-estimate.spec.ts tests/e2e/contractor-create-invoice.spec.ts tests/e2e/contractor-finalize-report.spec.ts tests/e2e/discover-geocoding-radius.spec.ts",
    "qa:e2e:production-auth-readonly-smoke": "node tests/helpers/check-production-smoke-env.mjs --auth-readonly --strict && playwright test tests/e2e/production-auth-readonly-smoke.spec.ts --project=chromium",
    "qa:e2e:production-public-smoke": "playwright test tests/e2e/production-public-smoke.spec.ts --project=chromium",
    "qa:e2e:readonly": "playwright test tests/e2e/contractor-smoke.spec.ts tests/e2e/homeowner-smoke.spec.ts",
    "qa:production-smoke:check": "node tests/helpers/check-production-smoke-env.mjs",
    "load:public": "k6 run tests/load/public-anonymous.js",
    "load:sandbox:auth-read": "k6 run tests/load/sandbox-auth-read.js",
    "load:check": "node tests/load/helpers/check-load-env.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:controlled-ops": "node --test tests/controlled-ops/*.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/analytics": "^2.0.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^8.0.16"
  }
}
